{
  "name": "mind-file-manager",
  "private": true,
  "version": "1.0.0",
  "description": "\u610f\u5ff5\u6587\u4ef6\u7ba1\u7406\u5668 v1.0 - \u4f01\u4e1a\u7ea7\u6587\u4ef6\u9884\u89c8\u4e0e\u7ba1\u7406\u89e3\u51b3\u65b9\u6848",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/13888285815/workbuddy-open-file-viewer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/13888285815/workbuddy-open-file-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/13888285815/workbuddy-open-file-viewer/issues"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "build:doc": "pnpm --filter @open-file-viewer/doc build",
    "build:examples": "pnpm -r --filter './examples/**' build",
    "pack:check": "node scripts/check-package-exports.mjs",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "check": "pnpm test && pnpm typecheck && pnpm build && pnpm build:examples && pnpm build:doc && pnpm pack:check",
    "dev:doc": "pnpm --filter @open-file-viewer/doc dev",
    "deploy:doc:void": "pnpm build:doc && void deploy --dir doc/dist --spa",
    "dev:vanilla": "pnpm --filter @open-file-viewer/example-vanilla dev",
    "dev:react": "pnpm --filter @open-file-viewer/example-react dev",
    "dev:vue": "pnpm --filter @open-file-viewer/example-vue dev",
    "dev:svelte": "pnpm --filter @open-file-viewer/example-svelte dev"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.0.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.2",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "react-dom": "^18.3.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}